{
  "name": "ionic-ui-lib",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "build": "ng build ionic-ui-lib",
    "build:prod": "ng build ionic-ui-lib --configuration production",
    "watch": "ng build ionic-ui-lib --watch --configuration development",
    "pack": "npm run build:prod && cd dist/ionic-ui-lib && npm pack",
    "publish:lib": "npm run build:prod && cd dist/ionic-ui-lib && npm publish --access public",
    "test": "ng test ionic-ui-lib"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.1",
    "@angular/cli": "^20.3.1",
    "@angular/compiler-cli": "^20.3.0",
    "@ionic/angular": "^8.8.8",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^20.3.0",
    "typescript": "~5.9.2"
  }
}
